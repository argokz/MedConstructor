# Docker Compose and local tooling. Copy this file to .env in the repository root.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=medical_constructor

# Backend inside Docker uses db:5432; host machine uses 127.0.0.1:5440
# DATABASE_URL for backend container is set in docker-compose.yml

# Local frontend only. Keep false in production.
NUXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false
