# Copy to .env and adjust. Never commit real production secrets.

# Local setup without Docker: use host 127.0.0.1 and the configured PostgreSQL port.
# Create the database and enable pgvector before starting the backend:
#   psql -h 127.0.0.1 -p 5440 -U postgres -d postgres -c "CREATE DATABASE medical_constructor;"
#   psql ... -d medical_constructor -c "CREATE EXTENSION IF NOT EXISTS vector;"
DATABASE_URL=postgresql+asyncpg://postgres:changeme@127.0.0.1:5440/medical_constructor

# Comma-separated list (no spaces after comma optional)
CORS_ORIGINS=http://localhost:3008,http://127.0.0.1:3008

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true
DB_ECHO=false

MAX_GRAPH_NODES=500
MAX_GRAPH_EDGES=2000

PRIMARY_LLM_PROVIDER=openai # openai or gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_MODELS=gemini-1.5-pro,gemini-1.5-flash
OPENAI_MODELS=gpt-5.1

# The default database schema stores 1536-dimensional vectors. Changing either
# the model or dimension requires rebuilding stored embeddings and migrating the
# pgvector columns before the service is started.
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_VECTOR_DIM=1536
EMBEDDING_BATCH_SIZE=64
CONCEPT_SIMILARITY_THRESHOLD=0.72
OPENAI_EMBEDDING_TIMEOUT=8
OPENAI_EMBEDDING_MAX_RETRIES=0
EVALUATION_EMBEDDING_TIMEOUT=10
CONCEPT_MATCHER_CACHE_TTL_SECONDS=300

ENABLE_STRUCTLOG=false
ENABLE_PROMETHEUS=true
ENABLE_OTEL=false

# JWT: replace this value in every non-development environment.
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Demo account seeding. Local/dev ONLY — never set ALLOW_DEMO_SEED=true in
# production. The seed scripts refuse to run unless this is 'true', and demo
# passwords have no hardcoded default: set them explicitly here for local login.
# In production the runtime demo importer generates a strong random password and
# leaves any existing (rotated) demo password untouched.
ALLOW_DEMO_SEED=false
DEMO_TEACHER_PASSWORD=
DEMO_STUDENT_PASSWORD=
DEMO_EXPERT_PASSWORD=
# If ENABLE_OTEL=true, install the OpenTelemetry FastAPI, SDK, and OTLP packages.
