# Продакшен (itwin.kz) — относительный путь; useApi добавит origin автоматически
NUXT_PUBLIC_API_BASE=/medical-api

# SSR на сервере ходит напрямую в backend (минуя nginx)
NUXT_INTERNAL_API_BASE=http://127.0.0.1:8012

# Локальная разработка без nginx — в .env.local:
# NUXT_PUBLIC_API_BASE=http://127.0.0.1:8012
